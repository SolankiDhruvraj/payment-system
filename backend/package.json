{
  "name": "payment-system-backend",
  "version": "1.0.0",
  "description": "Production-grade Payment Processing System with Razorpay integration",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon server.js",
    "start": "node server.js",
    "build": "npx prisma generate",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "node prisma/seed.js",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --runInBand",
    "test:unit": "node --experimental-vm-modules node_modules/.bin/jest tests/unit --runInBand",
    "test:integration": "node --experimental-vm-modules node_modules/.bin/jest tests/integration --runInBand",
    "test:coverage": "node --experimental-vm-modules node_modules/.bin/jest --coverage --runInBand"
  },
  "keywords": [
    "payment",
    "razorpay",
    "fintech",
    "nodejs"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^6.7.0",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.0.0",
    "joi": "^17.11.0",
    "razorpay": "^2.9.2",
    "uuid": "^9.0.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.0",
    "prisma": "^6.7.0",
    "supertest": "^6.3.4"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {},
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/config/**"
    ],
    "testMatch": [
      "**/tests/**/*.test.js"
    ]
  }
}
